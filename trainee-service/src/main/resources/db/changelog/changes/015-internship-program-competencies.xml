  <changeSet id="015-06-set-it-direction" author="Kasovich Pavel">
    <update tableName="internship_programs">
      <column name="it_direction" value="BACKEND"/>
      <where>id = 1</where>
    </update>
    <update tableName="internship_programs">
      <column name="it_direction" value="FRONTEND"/>
      <where>id = 2</where>
    </update>
    <update tableName="internship_programs">
      <column name="it_direction" value="DEVOPS"/>
      <where>id = 3</where>
    </update>
  </changeSet>

  <changeSet id="015-07-drop-legacy-competencies-column" author="Kasovich Pavel">
    <dropColumn tableName="internship_programs" columnName="competencies"/>
  </changeSet>

  <changeSet id="015-08-unique-title-lower-postgresql" author="Kasovich Pavel">
    <preConditions onFail="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>
      CREATE UNIQUE INDEX IF NOT EXISTS uq_internship_programs_title_lower ON internship_programs (LOWER(title));
    </sql>
  </changeSet>

  <changeSet id="015-09-competencies-sequence-sync-postgresql" author="Kasovich Pavel">
    <preConditions onFail="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>
      SELECT setval(
        pg_get_serial_sequence('competencies', 'id'),
        COALESCE((SELECT MAX(id) FROM competencies), 1)
      );
    </sql>
  </changeSet>
