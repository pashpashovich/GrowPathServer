<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="015-01-create-competencies" author="Kasovich Pavel">
    <createTable tableName="competencies">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false" unique="true"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="015-02-create-internship-program-competencies" author="Kasovich Pavel">
    <createTable tableName="internship_program_competencies">
      <column name="internship_program_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="competency_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addPrimaryKey tableName="internship_program_competencies"
                   columnNames="internship_program_id, competency_id"
                   constraintName="pk_internship_program_competencies"/>
    <addForeignKeyConstraint baseTableName="internship_program_competencies"
                             baseColumnNames="internship_program_id"
                             referencedTableName="internship_programs"
                             referencedColumnNames="id"
                             constraintName="fk_ipc_program"
                             onDelete="CASCADE"/>
    <addForeignKeyConstraint baseTableName="internship_program_competencies"
                             baseColumnNames="competency_id"
                             referencedTableName="competencies"
                             referencedColumnNames="id"
                             constraintName="fk_ipc_competency"
                             onDelete="CASCADE"/>
  </changeSet>

  <changeSet id="015-03-add-it-direction" author="Kasovich Pavel">
    <addColumn tableName="internship_programs">
      <column name="it_direction" type="VARCHAR(100)"/>
    </addColumn>
  </changeSet>

