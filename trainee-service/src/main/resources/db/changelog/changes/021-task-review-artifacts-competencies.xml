<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="021-01-task-statuses-reviewed-at" author="Kasovich Pavel">
    <addColumn tableName="tasks">
      <column name="reviewed_at" type="TIMESTAMP"/>
    </addColumn>
    <dropNotNullConstraint tableName="tasks" columnName="mentor_id" columnDataType="BIGINT"/>
  </changeSet>

  <changeSet id="021-02-task-comments" author="Kasovich Pavel">
    <createTable tableName="task_comments">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="task_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="comment" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="task_comments" baseColumnNames="task_id"
                             referencedTableName="tasks" referencedColumnNames="id"
                             onDelete="CASCADE" constraintName="fk_task_comments_task"/>
    <createIndex indexName="idx_task_comments_task_id" tableName="task_comments">
      <column name="task_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="021-03-task-artifacts" author="Kasovich Pavel">
    <createTable tableName="task_artifacts">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="task_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="artifact_type" type="VARCHAR(16)">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="content_type" type="VARCHAR(255)"/>
      <column name="size_bytes" type="BIGINT"/>
      <column name="object_key" type="VARCHAR(512)"/>
      <column name="url" type="VARCHAR(1024)">
        <constraints nullable="false"/>
      </column>
      <column name="uploaded_by" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="uploaded_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="task_artifacts" baseColumnNames="task_id"
                             referencedTableName="tasks" referencedColumnNames="id"
                             onDelete="CASCADE" constraintName="fk_task_artifacts_task"/>
    <createIndex indexName="idx_task_artifacts_task_id" tableName="task_artifacts">
      <column name="task_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="021-04-task-competencies" author="Kasovich Pavel">
    <createTable tableName="task_competencies">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="task_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="competency_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="task_competencies" baseColumnNames="task_id"
                             referencedTableName="tasks" referencedColumnNames="id"
                             onDelete="CASCADE" constraintName="fk_task_competencies_task"/>
    <addForeignKeyConstraint baseTableName="task_competencies" baseColumnNames="competency_id"
                             referencedTableName="competencies" referencedColumnNames="id"
                             onDelete="CASCADE" constraintName="fk_task_competencies_competency"/>
    <createIndex indexName="idx_task_competencies_task_id" tableName="task_competencies">
      <column name="task_id"/>
    </createIndex>
  </changeSet>
</databaseChangeLog>
