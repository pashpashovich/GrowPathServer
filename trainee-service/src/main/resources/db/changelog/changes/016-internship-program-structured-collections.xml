<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="016-01-requirements-table" author="Kasovich Pavel">
    <createTable tableName="internship_program_requirements">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="internship_program_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="requirement_text" type="TEXT">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="internship_program_requirements"
                             baseColumnNames="internship_program_id"
                             referencedTableName="internship_programs"
                             referencedColumnNames="id"
                             constraintName="fk_ipr_program"
                             onDelete="CASCADE"/>
    <createIndex indexName="idx_ipr_program" tableName="internship_program_requirements">
      <column name="internship_program_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="016-02-goals-table" author="Kasovich Pavel">
    <createTable tableName="internship_program_goals">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="internship_program_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="title" type="VARCHAR(500)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="TEXT"/>
    </createTable>
    <addForeignKeyConstraint baseTableName="internship_program_goals"
                             baseColumnNames="internship_program_id"
                             referencedTableName="internship_programs"
                             referencedColumnNames="id"
                             constraintName="fk_ipg_program"
                             onDelete="CASCADE"/>
    <createIndex indexName="idx_ipg_program" tableName="internship_program_goals">
      <column name="internship_program_id"/>
    </createIndex>
  </changeSet>

  <changeSet id="016-03-selection-stages-table" author="Kasovich Pavel">
    <createTable tableName="internship_program_selection_stages">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="internship_program_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="TEXT"/>
      <column name="is_active" type="BOOLEAN" defaultValueBoolean="true">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint baseTableName="internship_program_selection_stages"
                             baseColumnNames="internship_program_id"
                             referencedTableName="internship_programs"
                             referencedColumnNames="id"
                             constraintName="fk_ipss_program"
                             onDelete="CASCADE"/>
    <createIndex indexName="idx_ipss_program" tableName="internship_program_selection_stages">
      <column name="internship_program_id"/>
    </createIndex>
  </changeSet>

