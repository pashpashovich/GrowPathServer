  <changeSet id="016-07-drop-legacy-json-columns" author="Kasovich Pavel">
    <dropColumn tableName="internship_programs" columnName="requirements"/>
    <dropColumn tableName="internship_programs" columnName="goals"/>
    <dropColumn tableName="internship_programs" columnName="selection_stages"/>
  </changeSet>

  <changeSet id="016-08-sync-sequences-postgresql" author="Kasovich Pavel">
    <preConditions onFail="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>
      SELECT setval(pg_get_serial_sequence('internship_program_requirements', 'id'),
                    COALESCE((SELECT MAX(id) FROM internship_program_requirements), 1));
      SELECT setval(pg_get_serial_sequence('internship_program_goals', 'id'),
                    COALESCE((SELECT MAX(id) FROM internship_program_goals), 1));
      SELECT setval(pg_get_serial_sequence('internship_program_selection_stages', 'id'),
                    COALESCE((SELECT MAX(id) FROM internship_program_selection_stages), 1));
    </sql>
  </changeSet>
</databaseChangeLog>
