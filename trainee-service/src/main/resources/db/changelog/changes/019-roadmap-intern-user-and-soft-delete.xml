<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="019-01-roadmap-interns-user-id-cutover" author="Kasovich Pavel">
    <preConditions onFail="HALT">
      <sqlCheck expectedResult="0">
        SELECT COUNT(*) FROM roadmap_interns ri
                               LEFT JOIN users u ON ri.keycloak_user_id = u.keycloak_user_id
        WHERE u.id IS NULL
      </sqlCheck>

    </preConditions>
    <addColumn tableName="roadmap_interns">
      <column name="user_id" type="BIGINT"/>
    </addColumn>

    <sql>
      UPDATE roadmap_interns ri
      SET user_id = u.id FROM users u
      WHERE ri.keycloak_user_id = u.keycloak_user_id;
    </sql>

    <addNotNullConstraint tableName="roadmap_interns" columnName="user_id" columnDataType="BIGINT"/>
    <dropUniqueConstraint tableName="roadmap_interns" constraintName="uq_roadmap_intern"/>
    <addUniqueConstraint tableName="roadmap_interns" columnNames="roadmap_id, user_id"
                         constraintName="uq_roadmap_intern"/>
    <addForeignKeyConstraint baseTableName="roadmap_interns"
                             baseColumnNames="user_id"
                             referencedTableName="users"
                             referencedColumnNames="id"
                             constraintName="fk_ri_user"/>
    <dropIndex indexName="idx_roadmap_interns_keycloak" tableName="roadmap_interns"/>
    <createIndex indexName="idx_roadmap_interns_user" tableName="roadmap_interns">
      <column name="user_id"/>
    </createIndex>
    <dropColumn tableName="roadmap_interns" columnName="keycloak_user_id"/>
  </changeSet>

