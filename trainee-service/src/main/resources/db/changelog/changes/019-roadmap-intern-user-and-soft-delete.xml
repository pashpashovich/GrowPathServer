  <changeSet id="019-03-unique-indexes-for-soft-delete" author="Kasovich Pavel">
    <preConditions onFail="MARK_RAN">
      <dbms type="postgresql"/>
    </preConditions>
    <sql>
      ALTER TABLE users DROP CONSTRAINT IF EXISTS users_email_key;
      ALTER TABLE users DROP CONSTRAINT IF EXISTS users_keycloak_user_id_key;
      ALTER TABLE competencies DROP CONSTRAINT IF EXISTS competencies_name_key;
      ALTER TABLE it_directions DROP CONSTRAINT IF EXISTS it_directions_code_key;
      ALTER TABLE requirement_definitions DROP CONSTRAINT IF EXISTS requirement_definitions_requirement_text_key;
      ALTER TABLE user_registration_token DROP CONSTRAINT IF EXISTS user_registration_token_token_key;

      CREATE UNIQUE INDEX IF NOT EXISTS uq_users_email_active
        ON users (LOWER (email))
        WHERE deleted = false;
      CREATE UNIQUE INDEX IF NOT EXISTS uq_users_keycloak_user_id_active
        ON users (keycloak_user_id)
        WHERE deleted = false AND keycloak_user_id IS NOT NULL;
      CREATE UNIQUE INDEX IF NOT EXISTS uq_competencies_name_active
        ON competencies (LOWER (name))
        WHERE deleted = false;
      CREATE UNIQUE INDEX IF NOT EXISTS uq_it_directions_code_active
        ON it_directions (LOWER (code))
        WHERE deleted = false;
      CREATE UNIQUE INDEX IF NOT EXISTS uq_requirement_definitions_text_active
        ON requirement_definitions (requirement_text)
        WHERE deleted = false;
      CREATE UNIQUE INDEX IF NOT EXISTS uq_user_registration_token_token_active
        ON user_registration_token (token)
        WHERE deleted = false;
    </sql>
  </changeSet>

</databaseChangeLog>
