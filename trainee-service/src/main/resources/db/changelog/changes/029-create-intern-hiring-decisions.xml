<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

  <changeSet id="029-create-intern-hiring-decisions" author="Kasovich Pavel">
    <createTable tableName="intern_hiring_decisions">
      <column name="id" type="BIGSERIAL">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="intern_id" type="BIGINT">
        <constraints nullable="false"
                     foreignKeyName="fk_hiring_decision_intern"
                     references="users(id)"/>
      </column>
      <column name="internship_program_id" type="BIGINT">
        <constraints nullable="false"
                     foreignKeyName="fk_hiring_decision_program"
                     references="internship_programs(id)"/>
      </column>
      <column name="decision" type="VARCHAR(20)">
        <constraints nullable="false"/>
      </column>
      <column name="comment" type="TEXT">
        <constraints nullable="true"/>
      </column>
      <column name="decided_by_user_id" type="BIGINT">
        <constraints nullable="false"
                     foreignKeyName="fk_hiring_decision_decided_by"
                     references="users(id)"/>
      </column>
      <column name="decided_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="updated_at" type="TIMESTAMP">
        <constraints nullable="true"/>
      </column>
    </createTable>

    <addUniqueConstraint tableName="intern_hiring_decisions"
                         columnNames="intern_id, internship_program_id"
                         constraintName="uq_hiring_decision_intern_program"/>

    <createIndex indexName="idx_hiring_decision_program"
                 tableName="intern_hiring_decisions">
      <column name="internship_program_id"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
