{
  "type": "object",
  "properties": {
    "iprId": {
      "type": "integer",
      "format": "int64",
      "description": "IPR identifier"
    },
    "internId": {
      "type": "integer",
      "format": "int64",
      "description": "Intern identifier"
    },
    "overallProgress": {
      "type": "number",
      "format": "double",
      "description": "Overall completion percentage (0-100)",
      "minimum": 0,
      "maximum": 100
    },
    "completedTasks": {
      "type": "integer",
      "description": "Number of completed tasks"
    },
    "totalTasks": {
      "type": "integer",
      "description": "Total number of tasks"
    },
    "completedStages": {
      "type": "integer",
      "description": "Number of completed stages"
    },
    "totalStages": {
      "type": "integer",
      "description": "Total number of stages"
    },
    "status": {
      "type": "string",
      "enum": [
        "ON_TRACK",
        "BEHIND_SCHEDULE",
        "AHEAD_OF_SCHEDULE"
      ],
      "description": "Progress status"
    },
    "estimatedCompletionDate": {
      "type": "string",
      "format": "date",
      "description": "Estimated completion date"
    },
    "plannedEndDate": {
      "type": "string",
      "format": "date",
      "description": "Planned end date"
    },
    "stageProgress": {
      "type": "array",
      "description": "Progress details by stage",
      "items": {
        "type": "object",
        "properties": {
          "stageId": {
            "type": "integer",
            "format": "int64"
          },
          "stageTitle": {
            "type": "string"
          },
          "progressPercentage": {
            "type": "number",
            "format": "double"
          },
          "completedTasks": {
            "type": "integer"
          },
          "totalTasks": {
            "type": "integer"
          },
          "startDate": {
            "type": "string",
            "format": "date"
          },
          "endDate": {
            "type": "string",
            "format": "date"
          },
          "status": {
            "type": "string"
          }
        }
      }
    },
    "averageTaskRating": {
      "type": "number",
      "format": "double",
      "description": "Average rating of completed tasks"
    }
  },
  "required": [
    "iprId",
    "internId",
    "overallProgress",
    "completedTasks",
    "totalTasks",
    "completedStages",
    "totalStages",
    "status",
    "estimatedCompletionDate",
    "plannedEndDate",
    "stageProgress",
    "averageTaskRating"
  ]
}
