{
  "type": "object",
  "required": [
    "programId",
    "decision"
  ],
  "properties": {
    "programId": {
      "type": "integer",
      "format": "int64"
    },
    "decision": {
      "type": "string",
      "enum": [
        "recommended_for_hire",
        "talent_reserve",
        "completed_without_hire",
        "additional_assessment"
      ],
      "description": "Финальное решение (UC-14) или запрос дополнительной оценки"
    },
    "comment": {
      "type": "string",
      "description": "Обоснование решения"
    }
  }
}
