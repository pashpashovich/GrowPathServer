{
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "assigneeId": {
      "nullable": true,
      "type": "integer",
      "format": "int64"
    },
    "iprId": {
      "type": "integer",
      "format": "int64",
      "description": "Optional IPR id; used to validate iprStageId"
    },
    "iprStageId": {
      "type": "integer",
      "format": "int64",
      "description": "IPR stage id (ipr_stages.id)"
    },
    "stageId": {
      "type": "integer",
      "format": "int64",
      "description": "Alias for iprStageId (IPR stage id)"
    },
    "dueDate": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "submitted",
        "on_review",
        "needs_rework",
        "completed",
        "rejected"
      ],
      "description": "Optional status transition; same rules as PATCH /tasks/{id}/status (validated server-side)."
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Artifact links when transitioning to on_review / submitted."
    },
    "comment": {
      "type": "string",
      "description": "Submission comment (on_review) or optional mentor comment (completed)."
    },
    "rating": {
      "type": "integer",
      "format": "int32",
      "description": "Required when transitioning to completed via PUT."
    },
    "feedback": {
      "type": "string",
      "description": "Required when transitioning to needs_rework via PUT."
    },
    "competencyIds": {
      "type": "array",
      "description": "Replace task competencies; must belong to the task internship program",
      "items": {
        "type": "integer",
        "format": "int64"
      }
    }
  }
}
