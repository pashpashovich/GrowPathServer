{
  "type": "object",
  "required": [
    "objectKey",
    "name",
    "contentType",
    "sizeBytes"
  ],
  "properties": {
    "objectKey": {
      "type": "string",
      "description": "S3 object key returned after upload",
      "example": "tasks/123/artifacts/uuid-report.pdf"
    },
    "name": {
      "type": "string",
      "description": "Original file name",
      "example": "report.pdf"
    },
    "contentType": {
      "type": "string",
      "description": "MIME type of the file",
      "example": "application/pdf"
    },
    "sizeBytes": {
      "type": "integer",
      "format": "int64",
      "description": "File size in bytes",
      "example": 1048576
    }
  }
}
