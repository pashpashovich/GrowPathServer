{
  "type": "object",
  "required": [
    "title",
    "description",
    "priority",
    "internshipId"
  ],
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "assigneeIds": {
      "type": "array",
      "items": {
        "type": "integer",
        "format": "int64"
      }
    },
    "internshipId": {
      "type": "integer",
      "format": "int64"
    },
    "stageId": {
      "nullable": true,
      "type": "integer",
      "format": "int64"
    },
    "dueDate": {
      "type": "string",
      "format": "date-time"
    }
  }
}
