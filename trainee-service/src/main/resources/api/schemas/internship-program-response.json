{
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "startDate": {
      "type": "string",
      "format": "date"
    },
    "duration": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12
    },
    "maxPlaces": {
      "type": "integer"
    },
    "itDirection": {
      "type": "string"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "goals": {
      "type": "array",
      "items": {
        "$ref": "./program-goal.json"
      }
    },
    "competencyRefs": {
      "type": "array",
      "items": {
        "$ref": "./competency-ref.json"
      }
    },
    "selectionStages": {
      "type": "array",
      "items": {
        "$ref": "./selection-stage.json"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "draft",
        "completed",
        "cancelled",
        "archived"
      ]
    },
    "createdBy": {
      "type": "integer",
      "format": "int64"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "internships": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "id",
    "title",
    "status",
    "createdAt"
  ]
}
