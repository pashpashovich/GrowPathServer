{
  "type": "object",
  "required": ["token", "newPassword"],
  "properties": {
    "token": {
      "type": "string",
      "minLength": 1,
      "description": "One-time token from the password reset link"
    },
    "newPassword": {
      "type": "string",
      "format": "password",
      "minLength": 8,
      "description": "New password for Keycloak login"
    }
  }
}
