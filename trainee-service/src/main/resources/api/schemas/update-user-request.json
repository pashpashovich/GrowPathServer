{
  "type": "object",
  "properties": {
    "firstName": {
      "type": "string",
      "description": "Given name (must be sent together with lastName when updating)"
    },
    "lastName": {
      "type": "string",
      "description": "Family name (must be sent together with firstName when updating)"
    },
    "patronymicName": {
      "type": "string",
      "description": "Patronymic; omit to leave unchanged, empty string clears"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User email address"
    },
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "hr",
        "mentor",
        "intern",
        "department_head"
      ],
      "description": "User role"
    },
    "departmentId": {
      "type": "integer",
      "format": "int64",
      "description": "Department ID"
    }
  }
}
