{
  "type": "object",
  "properties": {
    "role": {
      "type": "string",
      "enum": [
        "admin",
        "hr",
        "mentor",
        "intern",
        "department_head"
      ]
    },
    "filters": {
      "type": "object",
      "properties": {
        "dateFrom": {
          "type": "string",
          "format": "date-time"
        },
        "dateTo": {
          "type": "string",
          "format": "date-time"
        },
        "departmentId": {
          "type": "integer",
          "format": "int64"
        },
        "programId": {
          "type": "integer",
          "format": "int64"
        },
        "mentorId": {
          "type": "integer",
          "format": "int64"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed", "on_hold"]
        }
      }
    },
    "stats": {
      "type": "object",
      "properties": {
        "totalUsers": {
          "type": "integer"
        },
        "activeInterns": {
          "type": "integer"
        },
        "activePrograms": {
          "type": "integer"
        },
        "pendingTasks": {
          "type": "integer"
        },
        "completedTasks": {
          "type": "integer"
        },
        "overdueTasks": {
          "type": "integer"
        },
        "averageTaskRating": {
          "type": "number",
          "format": "double"
        },
        "taskCompletionRate": {
          "type": "number",
          "format": "double",
          "description": "Percentage of tasks completed on time"
        },
        "averageTaskCompletionTime": {
          "type": "number",
          "format": "double",
          "description": "Average task completion time in days"
        }
      }
    },
    "trends": {
      "type": "object",
      "properties": {
        "internsGrowth": {
          "type": "string",
          "description": "Percentage change in interns (e.g., '+12%')"
        },
        "tasksCompletionGrowth": {
          "type": "string",
          "description": "Percentage change in completed tasks"
        },
        "averageRatingChange": {
          "type": "string",
          "description": "Change in average rating (e.g., '+0.3')"
        }
      }
    },
    "topPerformers": {
      "type": "array",
      "items": {
        "$ref": "./top-performer.json"
      },
      "description": "Top 5 performing interns"
    },
    "recentActivity": {
      "type": "array",
      "items": {
        "$ref": "./recent-activity.json"
      }
    },
    "upcomingDeadlines": {
      "type": "array",
      "items": {
        "$ref": "./upcoming-deadline.json"
      }
    }
  },
  "required": [
    "role",
    "stats"
  ]
}
