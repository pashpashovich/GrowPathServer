{
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "internId": {
      "type": "integer",
      "format": "int64"
    },
    "programId": {
      "type": "integer",
      "format": "int64"
    },
    "programTitle": {
      "type": "string"
    },
    "recorded": {
      "type": "boolean",
      "description": "true если решение уже утверждено и сохранено"
    },
    "decision": {
      "type": "string",
      "enum": [
        "recommended_for_hire",
        "talent_reserve",
        "completed_without_hire",
        "additional_assessment"
      ]
    },
    "systemRecommendation": {
      "type": "string",
      "enum": [
        "recommended_for_hire",
        "talent_reserve",
        "completed_without_hire",
        "additional_assessment"
      ],
      "description": "Автоматическая рекомендация на основе ИПР и оценок"
    },
    "systemRecommendationReason": {
      "type": "string"
    },
    "internStatus": {
      "type": "string",
      "enum": [
        "active",
        "additional_assessment",
        "completed",
        "paused"
      ],
      "description": "Текущий статус профиля стажёра"
    },
    "comment": {
      "type": "string"
    },
    "decidedByUserId": {
      "type": "integer",
      "format": "int64"
    },
    "decidedByName": {
      "type": "string"
    },
    "decidedAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "internId",
    "programId",
    "recorded",
    "systemRecommendation",
    "systemRecommendationReason",
    "internStatus"
  ]
}
